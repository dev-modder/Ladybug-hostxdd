# LADYBUGNODES V(5.1) Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Server Port (default: 3000)
PORT=3000

# Node environment (development, production)
NODE_ENV=development

# Your Render service URL (for keep-alive pings)
RENDER_URL=https://your-service.onrender.com

# ═══════════════════════════════════════════════════════════════════════════════
# Authentication
# ═══════════════════════════════════════════════════════════════════════════════
# Admin credentials (CHANGE THESE IN PRODUCTION!)
ADMIN_USERNAME=devntando
ADMIN_PASSWORD=ntando
ADMIN_EMAIL=admin@ladybugnodes.com

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-me

# ═══════════════════════════════════════════════════════════════════════════════
# MongoDB Database (Optional - Falls back to file-based storage)
# ═══════════════════════════════════════════════════════════════════════════════
# MongoDB Connection URI
# Get a free MongoDB Atlas cluster at: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ladybugnodes?retryWrites=true&w=majority

# ═══════════════════════════════════════════════════════════════════════════════
# WhatsApp API (Optional - For OTP verification)
# ═══════════════════════════════════════════════════════════════════════════════
# WhatsApp Business API credentials
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ═══════════════════════════════════════════════════════════════════════════════
# Email Configuration (Optional - For notifications)
# ═══════════════════════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=LADYBUGNODES <noreply@ladybugnodes.com>

# ═══════════════════════════════════════════════════════════════════════════════
# Rate Limiting
# ═══════════════════════════════════════════════════════════════════════════════
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100